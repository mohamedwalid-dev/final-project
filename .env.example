# ─── .env.example ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Backend URL ────────────────────────────────────────────────────────────────
# Development (local Django / FastAPI / Node / etc.)
VITE_API_BASE_URL=http://localhost:8000/api

# Production
# VITE_API_BASE_URL=https://api.your-domain.com/api

# ── API Version ────────────────────────────────────────────────────────────────
VITE_API_VERSION=v1

# ── Mock Mode ──────────────────────────────────────────────────────────────────
# true  → use mock data (default — safe for development without a backend)
# false → use real API calls (set this when backend is ready)
VITE_USE_MOCK=true

# ── Other (optional) ───────────────────────────────────────────────────────────
# VITE_SENTRY_DSN=https://your-sentry-dsn
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
