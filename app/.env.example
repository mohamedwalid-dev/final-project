# ── AI ERP System — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.

# App
APP_NAME="AI Enterprise Operating System"
APP_VERSION="2.0.0"
DEBUG=false

# LLM Provider: google | openai | ollama
LLM_PROVIDER=google

# Google Gemini — get key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# LangChain tuning
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024


